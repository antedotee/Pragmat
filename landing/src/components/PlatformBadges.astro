---
// Cross-platform chips. Pragmat ships for every desktop — Apple Silicon &
// Intel Macs, Windows, and Linux (the Tauri bundle targets are "all").
interface Props {
  tone?: "light" | "gradient";
  class?: string;
}
const { tone = "light", class: className = "" } = Astro.props;
const items = [
  { os: "apple", label: "Apple Silicon" },
  { os: "apple", label: "Intel Mac" },
  { os: "windows", label: "Windows" },
  { os: "linux", label: "Linux" },
];
---

<ul
  class={`platforms platforms-${tone} ${className}`}
  aria-label="Available for Apple Silicon Macs, Intel Macs, Windows, and Linux"
>
  {
    items.map((it) => (
      <li class="platform-chip">
        {it.os === "apple" && (
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35-4.88-5-4.16-12.66 1.38-12.94 1.27.06 2.16.74 2.92.8 1.13-.23 2.21-.89 3.42-.8 1.45.12 2.54.69 3.26 1.74-3 1.83-2.27 5.78.48 6.88-.55 1.45-1.27 2.89-2.45 3.96l-.03-.01ZM12.03 7.25c-.14-2.13 1.59-3.87 3.57-4.04.27 2.46-2.24 4.28-3.57 4.04Z" />
          </svg>
        )}
        {it.os === "windows" && (
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <rect x="3" y="3" width="8" height="8" rx="1" />
            <rect x="13" y="3" width="8" height="8" rx="1" />
            <rect x="3" y="13" width="8" height="8" rx="1" />
            <rect x="13" y="13" width="8" height="8" rx="1" />
          </svg>
        )}
        {it.os === "linux" && (
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M12 2.2c-2 0-3.3 1.6-3.3 4 0 1.2-.1 1.9-.8 2.9C6.2 11.3 5.3 13.4 5.3 15.8c0 3.1 2.9 5.7 6.7 5.7s6.7-2.6 6.7-5.7c0-2.4-.9-4.5-2.6-6.7-.7-1-.8-1.7-.8-2.9 0-2.4-1.3-4-3.3-4Z"
            />
            <ellipse cx="12" cy="15.4" rx="2.9" ry="3.9" fill="#fff" opacity="0.85" />
            <circle cx="10.7" cy="6.4" r="0.85" fill="#fff" />
            <circle cx="13.3" cy="6.4" r="0.85" fill="#fff" />
            <path d="M11.1 7.6h1.8l-.9 1.2z" fill="#fe640b" />
          </svg>
        )}
        <span>{it.label}</span>
      </li>
    ))
  }
</ul>
