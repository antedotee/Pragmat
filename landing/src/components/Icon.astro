---
// The Pragmat app mark, inlined so it stays crisp and themeable at any size.
interface Props {
  size?: number;
  class?: string;
}
const { size = 32, class: className = "" } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 200 200"
  class={className}
  role="img"
  aria-label="Pragmat"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <linearGradient id={`g-momentum-${size}`} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#afd6ee"></stop>
      <stop offset="1" stop-color="#48cde5"></stop>
    </linearGradient>
  </defs>
  <rect width="200" height="200" rx="45" fill={`url(#g-momentum-${size})`}></rect>
  <g fill="#ffffff">
    <circle cx="46" cy="155" r="6" fill-opacity="0.32"></circle>
    <circle cx="72" cy="130" r="8" fill-opacity="0.48"></circle>
    <circle cx="99" cy="103" r="10.5" fill-opacity="0.66"></circle>
    <circle cx="127" cy="72" r="13.5" fill-opacity="0.85"></circle>
  </g>
  <circle cx="153" cy="44" r="17.5" fill="#fe640b"></circle>
</svg>
